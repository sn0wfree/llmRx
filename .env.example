# llmRx environment overrides for docker compose.
# Copy to `.env` and edit. The shipped docker-compose.yml references
# these via ${VAR} substitution; entries commented out are optional.

# ----- at-rest encryption master key (P0) -----
# Strongly recommended for any non-localhost deployment.
# Generate with:    openssl rand -hex 32
# When unset, the entrypoint auto-generates /data/llmrx.key (DEV ONLY).
# LLMRX_KEY_MASTER=

# Upstream provider keys (used by config.yml ${VAR} expansion).
# DEEPSEEK_API_KEY=
# MINIMAX_API_KEY=

# Dev-only: skip master-key requirement entirely (channels stored in
# plaintext). Set to "true" to enable. DO NOT use in production.
# DEV_ALLOW_PLAINTEXT_KEYS=false