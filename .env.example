# llmRx environment overrides for docker compose.
#
# Copy to `.env` and edit. The shipped docker-compose.yml references
# these via ${VAR} substitution; entries commented out are optional.
# NEVER commit `.env` to git (already in .gitignore).

# ============================================================================
# at-rest encryption master key (P0)
# ============================================================================
# Strongly recommended for any non-localhost deployment.
# Generate with:    openssl rand -hex 32
# When unset, the entrypoint auto-generates /data/llmrx.key (DEV ONLY).
# LLMRX_KEY_MASTER=

# ============================================================================
# runtime
# ============================================================================
# Database DSN. Default points at the mounted /data volume.
# LLMRX_DB=/data/llmrx.db

# Listen address (host:port). Default ":8787" binds all interfaces.
# LLMRX_LISTEN=:8787

# Timezone for log timestamps and the daily cleanup loop.
# TZ=UTC

# Data directory (mostly relevant for bare-metal / systemd; in Docker
# the binary uses /data by default). The directory will be chowned
# to the `llmrx` user on first boot if it's currently root-owned
# (typical when bind-mounting a host-created dir).
# LLMRX_DATA_DIR=/data

# ============================================================================
# upstream provider keys (consumed by config.yml ${VAR} expansion)
# ============================================================================
# DEEPSEEK_API_KEY=
# MINIMAX_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ============================================================================
# egress proxy (Go stdlib recognises these automatically)
# ============================================================================
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1

# ============================================================================
# Go runtime tuning
# ============================================================================
# GC target percentage. Default 100. Lower = more frequent GC, less
# peak memory. Bump to 200+ for high-throughput / low-latency.
# GOGC=100

# Max OS threads. Default = runtime.NumCPU(). Usually leave alone.
# GOMAXPROCS=

# ============================================================================
# dev-only escape hatches — DO NOT enable in production
# ============================================================================
# Skip the master-key requirement entirely. Channel API keys get
# stored in PLAINTEXT in the DB. Only useful for throwaway test
# environments.
# DEV_ALLOW_PLAINTEXT_KEYS=false